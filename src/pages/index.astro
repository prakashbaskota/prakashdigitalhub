---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Prakash Baskota | IT Infrastructure Engineer | Microsoft 365 & Network Specialist',
  description: 'Professional IT consultant specializing in Microsoft 365, Windows Server, network infrastructure, cybersecurity, backup solutions, and web development.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Hire Me',
        href: '#contact',
        icon: 'tabler:briefcase',
      },
      { text: 'View My Work', href: '#projects' },
      { text: 'Download CV', href: '#', icon: 'tabler:download' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Prakash Baskota IT Solutions' }}
  >
    <Fragment slot="title">
      Building Secure, Reliable & Modern
      <span class="text-accent dark:text-white"> IT Solutions</span> for Businesses
    </Fragment>

    <Fragment slot="subtitle">
      I help organizations design, manage, and optimize their IT infrastructure through enterprise networking, Microsoft 365 solutions, cybersecurity, backup strategies, and modern web technologies.
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <Note title="Prakash Digital Hub" description="Secure Infrastructure. Reliable Technology. Digital Growth." />

  <!-- Features Widget *************** -->

  <Features
    id="services"
    columns={3}
    tagline="Professional Services"
    title="Enterprise IT Solutions I Provide"
    subtitle="Specialized expertise in infrastructure, networking, cloud services, security, and modern web development"
    items={[
      {
        title: 'IT Infrastructure Management',
        description:
          'Designing, maintaining, and supporting reliable enterprise IT environments including servers, workstations, applications, and business systems.',
        icon: 'tabler:server-2',
      },
      {
        title: 'Network Engineering',
        description:
          'Building secure and efficient network infrastructures that keep businesses connected and productive with LAN/WAN, VPN, and firewall solutions.',
        icon: 'tabler:network',
      },
      {
        title: 'Microsoft 365 Solutions',
        description:
          'Helping organizations manage and optimize Microsoft cloud services for collaboration, communication, and security including Exchange, Teams, and SharePoint.',
        icon: 'tabler:cloud',
      },
      {
        title: 'Cybersecurity & Protection',
        description:
          'Implementing security practices to protect business systems, users, and data through firewall management, access control, and endpoint security.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Backup & Disaster Recovery',
        description:
          'Creating reliable backup strategies to protect critical business information and ensure continuity with automated recovery planning.',
        icon: 'tabler:database-cog',
      },
      {
        title: 'Website Development',
        description:
          'Creating fast, modern, SEO-friendly websites using latest web technologies like Astro, Tailwind CSS, JavaScript, and deployed on Vercel.',
        icon: 'tabler:code',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    id="about"
    tagline="About Me"
    title="Experienced IT Professional & Solutions Architect"
    items={[
      {
        title: 'Infrastructure Expertise',
        description:
          'Deep hands-on experience managing enterprise IT environments including Windows Server, Active Directory, DNS, DHCP, and business-critical applications.',
      },
      {
        title: 'Cloud & Modern Technologies',
        description:
          'Specialized knowledge in Microsoft 365 administration, cloud infrastructure, backup solutions, and modern development practices.',
      },
      {
        title: 'Security & Reliability',
        description:
          'Committed to building secure, reliable, and scalable technology solutions that reduce operational challenges and improve business productivity.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1517694712202-14dd9538aa97?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'IT Professional Solutions',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">About Prakash Baskota</h3>
      <p class="text-lg mb-4">
        I am an experienced IT professional specializing in infrastructure management, system administration, network engineering, Microsoft 365 administration, cybersecurity, and web development.
      </p>
      <p class="text-lg mb-4">
        My experience includes managing enterprise IT environments, Windows Server infrastructure, Active Directory, Microsoft cloud services, firewall solutions, backup systems, and business-critical applications.
      </p>
      <p class="text-lg">
        Beyond IT infrastructure, I enjoy developing modern websites and digital solutions using current technologies such as Astro, Tailwind CSS, JavaScript, GitHub, and Vercel. Available for remote IT consulting and technical support worldwide with flexible support for international clients.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    tagline="Why Work With Me"
    title="Benefits of Partnering with Prakash Digital Hub"
    items={[
      {
        title: 'Reliable',
        description: 'Focused on building stable and secure IT environments that you can depend on.',
      },
      {
        title: 'Experienced',
        description:
          'Hands-on experience solving real business IT challenges with proven methodologies.',
      },
      {
        title: 'Security Focused',
        description:
          'Following industry best practices for protecting business systems, data, and user information.',
      },
      {
        title: 'Continuous Learning',
        description:
          'Always improving knowledge with modern technologies and emerging industry standards.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Professional Services',
    }}
  >
    <Fragment slot="content">Trusted Partner for Your IT Infrastructure Needs</Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent
    id="projects"
    tagline="Featured Projects"
    title="Real-World Solutions & Case Studies"
    items={[
      {
        title: 'Enterprise IT Infrastructure Management',
        description:
          'Managed enterprise IT environments including Windows Server, Active Directory, network infrastructure, user management, security policies, and troubleshooting.',
      },
      {
        title: 'Microsoft 365 Administration',
        description:
          'Implemented and managed Microsoft 365 services including user accounts, Exchange Online, Teams, OneDrive, SharePoint, licensing, and security configurations.',
      },
      {
        title: 'Network Security & Firewall Management',
        description:
          'Configured and maintained secure network environments using firewall policies, VPN solutions, and network monitoring practices.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'IT Projects & Solutions',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Proven Project Experience</h3>
      I deliver measurable results through strategic planning, expert implementation, and ongoing optimization.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    id="experience"
    title="My Professional Engagement Process"
    items={[
      {
        title: 'Step 1: <span class="font-medium">Assessment & Consultation</span>',
        description:
          "In-depth analysis of your current IT infrastructure, systems, and business requirements. I evaluate gaps, identify opportunities, and understand your specific objectives.",
        icon: 'tabler:search',
      },
      {
        title: 'Step 2: <span class="font-medium">Strategy & Planning</span>',
        description:
          'Development of comprehensive roadmap aligned with your business goals. Detailed planning ensures efficient resource allocation, minimized downtime, and optimal outcomes.',
        icon: 'tabler:layout-kanban',
      },
      {
        title: 'Step 3: <span class="font-medium">Implementation & Deployment</span>',
        description:
          'Precise execution of planned solutions with meticulous attention to detail. Seamless deployment minimizes disruption to your business operations.',
        icon: 'tabler:hammer',
      },
      {
        title: 'Step 4: <span class="font-medium">Monitoring & Optimization</span>',
        description:
          'Continuous monitoring and optimization ensures peak performance. Proactive support identifies and resolves issues before they impact your business.',
        icon: 'tabler:chart-line',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Professional IT Services Workflow',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    id="skills"
    title="Technical Skills & Proficiency"
    subtitle="Expert-level capabilities across infrastructure, networking, cloud services, and modern web development"
    tagline="Technical Expertise"
    items={[
      {
        title: 'Infrastructure Management',
        description: 'Windows Server, Active Directory, Group Policy, DNS, DHCP, File Services, System Administration',
        icon: 'tabler:server-2',
      },
      {
        title: 'Networking',
        description:
          'TCP/IP, LAN/WAN, VLAN, VPN, Firewall Management, Routing, Switching, Network Design',
        icon: 'tabler:network',
      },
      {
        title: 'Microsoft 365',
        description:
          'Exchange Online, Teams, SharePoint, OneDrive, Azure AD, User Management, Licensing, Security',
        icon: 'tabler:cloud',
      },
      {
        title: 'Cybersecurity',
        description:
          'Firewall Configuration, Access Control, Endpoint Security, Backup Security, Security Monitoring',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Backup & Disaster Recovery',
        description: 'Server Backup, Microsoft 365 Backup, Recovery Planning, Automation, Business Continuity',
        icon: 'tabler:database-cog',
      },
      {
        title: 'Web Development',
        description:
          'HTML/CSS, JavaScript, Astro Framework, Tailwind CSS, GitHub, Vercel, Web Performance, SEO',
        icon: 'tabler:code',
      },
      {
        title: 'Cloud Platforms',
        description: 'Microsoft Azure, AWS Services, Cloud Migration, Infrastructure as Code, Cloud Security',
        icon: 'tabler:cloud-upload',
      },
      {
        title: 'DevOps & Automation',
        description: 'CI/CD Pipelines, Infrastructure Automation, Containerization, Configuration Management',
        icon: 'tabler:robot',
      },
      {
        title: 'Monitoring & Analytics',
        description: 'System Monitoring, Log Management, Performance Analytics, Alerting, Reporting',
        icon: 'tabler:chart-line',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- HighlightedPosts Widget ******* -->

  <BlogLatestPosts
    title="Project Highlights & Case Studies"
    information={`Portfolio of successful IT infrastructure projects, network implementations, Microsoft 365 migrations, and modern website developments. Each project demonstrates expertise in designing and deploying enterprise-grade solutions.`}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    id="faq"
    title="Frequently Asked Questions"
    subtitle="Find answers to common questions about my IT consulting services, expertise, and engagement process."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'What services do you provide?',
        description:
          'I provide comprehensive IT consulting including infrastructure management, network engineering, Microsoft 365 administration, cybersecurity, backup solutions, disaster recovery planning, and modern website development.',
      },
      {
        title: 'Do you offer remote support?',
        description:
          'Yes, I am available for remote IT consulting and technical support worldwide. I offer flexible support for international clients across different time zones.',
      },
      {
        title: 'What is your experience level?',
        description:
          'I have extensive hands-on experience managing enterprise IT environments including Windows Server infrastructure, Active Directory, network design, Microsoft cloud services, and security implementations.',
      },
      {
        title: 'How do you approach new projects?',
        description:
          'I follow a structured approach: Assessment & Consultation → Strategy & Planning → Implementation & Deployment → Monitoring & Optimization. This ensures solutions align with your business objectives.',
      },
      {
        title: 'What technologies do you specialize in?',
        description:
          'I specialize in Windows Server, Active Directory, Microsoft 365, network infrastructure, cybersecurity, backup solutions, cloud platforms, and modern web development using Astro and Tailwind CSS.',
      },
      {
        title: 'Can you help with Microsoft 365 migration?',
        description:
          'Yes, I have extensive experience with Microsoft 365 implementations including Exchange Online, Teams, SharePoint, OneDrive, user management, licensing, and security configurations.',
      },
      {
        title: 'What makes you different?',
        description:
          'I combine enterprise IT infrastructure expertise with modern web development skills. This full-stack technical knowledge allows me to provide comprehensive solutions and better understand business requirements.',
      },
      {
        title: 'How do I get started?',
        description:
          'Contact me to schedule a consultation. I will assess your current infrastructure, discuss your business objectives, and provide a tailored proposal for your needs.',
      },
    ]}
  />

  <!-- Stats Widget ****************** -->

  <Stats
    stats={[
      { title: 'Years Experience', amount: '20+' },
      { title: 'Projects Completed', amount: '24+' },
      { title: 'Business Clients', amount: '10+' },
      { title: 'Uptime Delivered', amount: '99.9%' },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    id="contact"
    actions={[
      {
        variant: 'primary',
        text: 'Schedule Consultation',
        href: 'mailto:prakashbaskota@gmail.com',
        icon: 'tabler:mail',
      },
      {
        variant: 'secondary',
        text: 'View LinkedIn',
        href: 'https://linkedin.com/in/prakashbaskota',
        target: '_blank',
        icon: 'tabler:brand-linkedin',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to Transform Your IT Infrastructure?
    </Fragment>

    <Fragment slot="subtitle">
      Contact me today to discuss your business challenges and how I can deliver secure, reliable technology solutions that drive growth.
    </Fragment>
  </CallToAction>
</Layout>
